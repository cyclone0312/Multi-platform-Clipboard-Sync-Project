{
    "terminal.integrated.defaultProfile.windows": "PowerShell UTF-8",
    "terminal.integrated.profiles.windows": {
        "PowerShell UTF-8": {
            "source": "PowerShell",
            "args": [
                "-NoExit",
                "-Command",
                "chcp 65001 > $null; [Console]::InputEncoding = [Text.UTF8Encoding]::new($false); [Console]::OutputEncoding = [Text.UTF8Encoding]::new($false); $OutputEncoding = [Text.UTF8Encoding]::new($false)"
            ]
        }
    },
    "terminal.integrated.fontFamily": "Cascadia Mono, Consolas, Microsoft YaHei UI"
}